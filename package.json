{
  "name": "zoocode-mcp-organic",
  "version": "1.0.0",
  "description": "Servidor MCP corporativo con repositorios de conocimiento para Organic y Lince",
  "main": "dist/server.js",
  "scripts": {
    "setup": "node setup.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "deploy:dev": "pm2 start ecosystem.config.js --env development",
    "deploy:prod": "pm2 start ecosystem.config.js --env production",
    "docker:build": "docker build -t mcp-organic .",
    "docker:run": "docker run --rm --name mcp-organic -e MCP_TRANSPORT=http -e MCP_SERVER_HOST=0.0.0.0 -e MCP_SERVER_PORT=3000 -p 3000:3000 mcp-organic"
  },
  "keywords": ["mcp", "knowledge-base", "copilot", "organic", "lince"],
  "author": "Equipo Arquitectura",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.0",
    "yaml": "^2.3.4",
    "winston": "^3.11.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "rimraf": "^5.0.0",
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
